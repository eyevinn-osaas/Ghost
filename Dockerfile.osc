FROM ghost:6-alpine

USER root

# Install bash for entrypoint
RUN apk add --no-cache bash

# Install pg module for PostgreSQL support (Ghost only ships with SQLite)
# --legacy-peer-deps needed due to bookshelf/knex peer dep conflict in Ghost
RUN cd /var/lib/ghost/current && npm install pg --legacy-peer-deps

COPY --chmod=755 osc-entrypoint.sh /usr/local/bin/osc-entrypoint.sh

# Ghost stores content in /var/lib/ghost/content by default
VOLUME ["/var/lib/ghost/content"]

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/osc-entrypoint.sh"]
CMD ["node", "current/index.js"]
